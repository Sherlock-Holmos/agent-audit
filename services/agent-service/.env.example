# agent-service 环境变量示例
# 复制为 .env 后修改对应值（docker-compose 通过变量注入，无需挂载此文件）

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── data-service 地址 ─────────────────────────────────────────────────────
DATA_BASE_URL=http://localhost:8082
AGENT_DASHBOARD_TIMEOUT_MS=2500
AGENT_DASHBOARD_RETRY_TIMES=1

# ── 会话 / 限流 ───────────────────────────────────────────────────────────
AGENT_SESSION_TTL_MINUTES=360
AGENT_MAX_SESSION_TURNS=20
AGENT_RATE_LIMIT_PER_MINUTE=30

# ── LLM 提供商（mock | openai | azure）────────────────────────────────────
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI（LLM_PROVIDER=azure 时填写以下变量）
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── RAG 向量数据库（预留，VECTOR_STORE_TYPE=none 时不启用）─────────────────
# 可选值：none | chroma | pgvector
VECTOR_STORE_TYPE=none

# Chroma（VECTOR_STORE_TYPE=chroma 时启用）
CHROMA_HOST=localhost
CHROMA_PORT=8000
VECTOR_COLLECTION=audit_knowledge
VECTOR_TOP_K=4

# pgvector（VECTOR_STORE_TYPE=pgvector 时启用）
# PGVECTOR_DSN=postgresql+psycopg2://user:password@localhost:5432/agent_audit
